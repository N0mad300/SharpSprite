<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SharpSprite.App.ViewModels"
             x:Class="SharpSprite.App.Controls.PaletteControl"
             x:DataType="vm:PaletteViewModel"
			 FontSize="26">

	<UserControl.Styles>

		<Style Selector="Button.swatch">
			<Setter Property="Width" Value="14"/>
			<Setter Property="Height" Value="14"/>
			<Setter Property="Margin" Value="1"/>
			<Setter Property="CornerRadius" Value="1"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="#2a2a2a"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>

		<Style Selector="Button.swatch:pointerover">
			<Setter Property="BorderBrush" Value="#aaaaaa"/>
			<Setter Property="BorderThickness" Value="1.5"/>
		</Style>

	</UserControl.Styles>

	<Grid RowDefinitions="Auto,*,Auto" Background="#252525">

		<!-- FG / BG color chips + swap -->
		<Grid Grid.Row="0" Margin="6,6,6,4" ColumnDefinitions="Auto,Auto,*,Auto">

			<!-- Background chip (behind) -->
			<Border Grid.Column="0"
					Width="22" Height="22"
					Margin="8,6,0,0"
					CornerRadius="2"
					BorderThickness="1.5"
					BorderBrush="#555"
					Background="{Binding BackgroundAvaloniaColor}"
					ToolTip.Tip="{Binding BackgroundHex}"
					ZIndex="0"/>

			<!-- Foreground chip (front, overlaps background) -->
			<Border Grid.Column="0"
					Width="22" Height="22"
					Margin="0,0,8,6"
					CornerRadius="2"
					BorderThickness="1.5"
					BorderBrush="#999"
					Background="{Binding ForegroundAvaloniaColor}"
					ToolTip.Tip="{Binding ForegroundHex}"
					ZIndex="1"/>

			<!-- Swap arrow -->
			<Button Grid.Column="1"
					Width="16" Height="16"
					Padding="0"
					Margin="2,0,0,0"
					Background="Transparent"
					BorderThickness="0"
					VerticalAlignment="Top"
					Command="{Binding SwapColorsCommand}"
					ToolTip.Tip="Swap FG/BG (X)">
				<TextBlock Text="⇄" FontSize="16" Foreground="#888"
						   HorizontalAlignment="Center" VerticalAlignment="Center"/>
			</Button>

			<!-- Reset -->
			<Button Grid.Column="1"
					Width="16" Height="16"
					Padding="0"
					Margin="2,14,0,0"
					Background="Transparent"
					BorderThickness="0"
					VerticalAlignment="Top"
					Command="{Binding ResetColorsCommand}"
					ToolTip.Tip="Reset to Black/White (D)">
				<TextBlock Text="↺" FontSize="16" Foreground="#666"
						   HorizontalAlignment="Center" VerticalAlignment="Center"/>
			</Button>

		</Grid>

		<!-- Swatch grid -->
		<ScrollViewer Grid.Row="1"
					  VerticalScrollBarVisibility="Auto"
					  HorizontalScrollBarVisibility="Disabled"
					  Margin="2,0,2,2">
			<ItemsControl ItemsSource="{Binding Swatches}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel Orientation="Horizontal"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="vm:SwatchViewModel">
						<Button Classes="swatch"
								Background="{Binding AvaloniaColor}"
								ToolTip.Tip="{Binding HexColor}"
								Command="{Binding $parent[UserControl].((vm:PaletteViewModel)DataContext).SelectSwatchCommand}"
								CommandParameter="{Binding}"
								PointerPressed="Swatch_PointerPressed"
								Padding="0"
								BorderThickness="0"/>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

		<!-- Index label at bottom -->
		<Border Grid.Row="2"
				Background="#1e1e1e"
				BorderThickness="0,1,0,0"
				BorderBrush="#3a3a3a"
				Padding="4,2">
			<TextBlock Text="{Binding IndexLabel}"
					   Foreground="#888"
					   HorizontalAlignment="Center"/>
		</Border>

	</Grid>
</UserControl>
